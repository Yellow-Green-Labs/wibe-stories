{
  "name": "Wibe Stories",
  "short_name": "Wibe Stories",
  "description": "Speak your words, share your story — turn your voice into beautiful, shareable cards in 44 languages.",
  "lang": "en",
  "dir": "ltr",
  "categories": ["social", "productivity", "lifestyle"],
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#1a1a1a",
  "theme_color": "#ffffeb",
  "icons": [
    {
      "src": "assets/ws-logo-blwbg.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "assets/ws-logo-blwbg.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Start a card",
      "short_name": "New card",
      "description": "Open Wibe Stories ready to record or type",
      "url": "/?source=shortcut-new",
      "icons": [
        { "src": "assets/ws-logo-blwbg.png", "sizes": "192x192", "type": "image/png" }
      ]
    }
  ],
  "share_target": {
    "action": "/",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text"
    }
  },
  "prefer_related_applications": false
}
