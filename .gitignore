# Internal logs folder — team-only source files are git-ignored.
# observer.js is un-ignored so it ships with the public site.
# Note: must use `*` not `/` here — a directory-level ignore prevents
# the `!` re-include rule from working (per Git docs).
internal-logs/*
!internal-logs/observer.js
